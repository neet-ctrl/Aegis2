<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <uses-permission android:name="android.permission.USE_FINGERPRINT" />

    <application
        android:name=".GetoApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Geto.Splash"
        tools:targetApi="31">

        <activity
            android:name=".activity.main.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <intent-filter>
                <action android:name="com.android.geto.ACTION_OPEN_DASHBOARD" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <activity
            android:name=".activity.shortcut.ShortcutActivity"
            android:excludeFromRecents="true"
            android:theme="@style/Theme.Geto.Shortcut" />

        <activity
            android:name=".lock.AppLockActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:launchMode="singleTask"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:theme="@style/Theme.Geto" />

        <service
            android:name=".lock.AppLockService"
            android:exported="true"
            android:label="@string/app_lock_service_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/app_lock_service" />
        </service>

        <!-- Quick Settings Tile: Aegis Dashboard -->
        <service
            android:name=".tile.AegisDashboardTileService"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:label="Aegis"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- Quick Settings Tile: Aegis Automations Toggle -->
        <service
            android:name=".tile.AegisAutomationTileService"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:label="Automations"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- Home Screen Widget -->
        <receiver
            android:name=".widget.AegisWidgetProvider"
            android:exported="true"
            android:label="Aegis Status Widget">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/aegis_widget_info" />
        </receiver>

    </application>

</manifest>
