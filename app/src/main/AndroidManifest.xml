<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ══════════════════════════════════════════
         Runtime Permissions (user popup dialog)
    ══════════════════════════════════════════ -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <uses-permission android:name="android.permission.USE_FINGERPRINT" />
    <uses-permission
        android:name="android.permission.POST_NOTIFICATIONS"
        android:minSdkVersion="33" />

    <!-- ══════════════════════════════════════════
         System Settings Page Permissions
         (granted via special Settings screens)
    ══════════════════════════════════════════ -->
    <uses-permission android:name="android.permission.WRITE_SETTINGS"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <uses-permission
        android:name="android.permission.SCHEDULE_EXACT_ALARM"
        android:minSdkVersion="31" />
    <uses-permission android:name="android.permission.ACCESS_NOTIFICATION_POLICY" />
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- ══════════════════════════════════════════
         AShell U / Signature Permissions
         (granted via: adb shell pm grant ...)
    ══════════════════════════════════════════ -->
    <uses-permission android:name="android.permission.WRITE_SECURE_SETTINGS"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.DUMP"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.READ_LOGS"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.CHANGE_CONFIGURATION"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.BATTERY_STATS"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.MANAGE_APP_OPS_MODES"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission android:name="android.permission.STATUS_BAR"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.READ_DEVICE_CONFIG"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.FORCE_STOP_PACKAGES"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.INTERACT_ACROSS_USERS"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.BROADCAST_STICKY" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- ══════════════════════════════════════════
         Automation Monitor Service
    ══════════════════════════════════════════ -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission
        android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC"
        android:minSdkVersion="34" />

    <!-- ══════════════════════════════════════════
         Bluetooth (for Bluetooth trigger detection)
    ══════════════════════════════════════════ -->
    <uses-permission android:name="android.permission.BLUETOOTH" />
    <uses-permission
        android:name="android.permission.BLUETOOTH_CONNECT"
        android:minSdkVersion="31"
        tools:ignore="ProtectedPermissions" />

    <!-- ══════════════════════════════════════════
         Network state (for Wi-Fi trigger detection)
    ══════════════════════════════════════════ -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />

    <application
        android:name=".GetoApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Geto.Splash"
        tools:targetApi="31">

        <activity
            android:name=".activity.main.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <intent-filter>
                <action android:name="com.android.geto.ACTION_OPEN_DASHBOARD" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <activity
            android:name=".activity.shortcut.ShortcutActivity"
            android:excludeFromRecents="true"
            android:theme="@style/Theme.Geto.Shortcut" />

        <activity
            android:name=".lock.AppLockActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:launchMode="singleTask"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:theme="@style/Theme.Geto" />

        <service
            android:name=".lock.AppLockService"
            android:exported="true"
            android:label="@string/app_lock_service_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/app_lock_service" />
        </service>

        <!-- Background monitor service: screen, battery, audio, Wi-Fi events -->
        <service
            android:name=".service.AegisMonitorService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- Quick Settings Tile: Aegis Dashboard -->
        <service
            android:name=".tile.AegisDashboardTileService"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:label="Aegis"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- Quick Settings Tile: Aegis Automations Toggle -->
        <service
            android:name=".tile.AegisAutomationTileService"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:label="Automations"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- Home Screen Widget: Status (shows automations + rules + last trigger) -->
        <receiver
            android:name=".widget.AegisWidgetProvider"
            android:exported="true"
            android:label="Aegis Status Widget">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/aegis_widget_info" />
        </receiver>

        <!-- Home Screen Widget: Automation Toggle (tap to pause/resume automations) -->
        <receiver
            android:name=".widget.AegisAutomationToggleWidgetProvider"
            android:exported="true"
            android:label="Aegis Automation Toggle">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.android.geto.ACTION_TOGGLE_AUTOMATIONS" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/aegis_widget_automation_toggle_info" />
        </receiver>

        <!-- Home Screen Widget: Dashboard (shows all key metrics) -->
        <receiver
            android:name=".widget.AegisDashboardWidgetProvider"
            android:exported="true"
            android:label="Aegis Dashboard Widget">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/aegis_widget_dashboard_info" />
        </receiver>

        <!-- Home Screen Widget: Activity (shows recent trigger log) -->
        <receiver
            android:name=".widget.AegisActivityWidgetProvider"
            android:exported="true"
            android:label="Aegis Activity Widget">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/aegis_widget_activity_info" />
        </receiver>

        <!-- FileProvider: serves APK and internal files for sharing -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- Boot receiver for automation engine restart -->
        <receiver
            android:name=".receiver.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>

        <!-- Static system event receiver: charger, Bluetooth, package events -->
        <receiver
            android:name=".receiver.AegisSystemTriggerReceiver"
            android:exported="false">
            <!-- Power and Bluetooth events — no data scheme required -->
            <intent-filter>
                <action android:name="android.intent.action.ACTION_POWER_CONNECTED" />
                <action android:name="android.intent.action.ACTION_POWER_DISCONNECTED" />
                <action android:name="android.bluetooth.device.action.ACL_CONNECTED" />
                <action android:name="android.bluetooth.device.action.ACL_DISCONNECTED" />
            </intent-filter>
            <!-- Package install / uninstall events — must match package: URI scheme -->
            <intent-filter>
                <action android:name="android.intent.action.PACKAGE_ADDED" />
                <action android:name="android.intent.action.PACKAGE_REMOVED" />
                <data android:scheme="package" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
