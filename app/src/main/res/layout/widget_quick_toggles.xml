                android:maxLines="1"
                android:ellipsize="end" />
            <TextView
                android:id="@+id/wqt_status_7"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OFF"
                android:textSize="8sp"
                android:textStyle="bold"
                android:textColor="#FF4CAF50" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:background="#22FFFFFF"
            android:padding="5dp"
            android:layout_marginStart="2dp">
            <TextView
                android:id="@+id/wqt_name_8"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Night Light"
                android:textSize="8sp"
                android:textColor="#CCFFFFFF"
                android:maxLines="1"
                android:ellipsize="end" />
            <TextView
                android:id="@+id/wqt_status_8"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OFF"
                android:textSize="8sp"
                android:textStyle="bold"
                android:textColor="#FF4CAF50" />
        </LinearLayout>

    </LinearLayout>

    <!-- Row 5: Toggle 9 & 10 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:background="#22FFFFFF"
            android:padding="5dp"
            android:layout_marginEnd="2dp">
            <TextView
                android:id="@+id/wqt_name_9"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Battery Saver"
                android:textSize="8sp"
                android:textColor="#CCFFFFFF"
                android:maxLines="1"
                android:ellipsize="end" />
            <TextView
                android:id="@+id/wqt_status_9"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OFF"
                android:textSize="8sp"
                android:textStyle="bold"
                android:textColor="#FF4CAF50" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:background="#22FFFFFF"
            android:padding="5dp"
            android:layout_marginStart="2dp">
            <TextView
                android:id="@+id/wqt_name_10"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Do Not Disturb"
                android:textSize="8sp"
                android:textColor="#CCFFFFFF"
                android:maxLines="1"
                android:ellipsize="end" />
            <TextView
                android:id="@+id/wqt_status_10"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OFF"
                android:textSize="8sp"
                android:textStyle="bold"
                android:textColor="#FF4CAF50" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
