            <TextView
                android:id="@+id/wqt_status_4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OFF"
                android:textSize="7sp"
                android:textColor="#AAFFFFFF" />
        </LinearLayout>

    </LinearLayout>

    <!-- Row 3 -->
    <LinearLayout
