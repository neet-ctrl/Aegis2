<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_toggle_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@mipmap/ic_launcher"
            android:scaleType="fitCenter"
            android:contentDescription="@null" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="AEGIS AUTOMATIONS"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#99FFFFFF"
            android:letterSpacing="0.08" />

        <TextView
            android:id="@+id/widget_toggle_indicator"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="#FF2E7D32" />

    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp"
        android:background="#33FFFFFF" />

    <TextView
        android:id="@+id/widget_toggle_state"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Automations ON"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:gravity="center" />

    <TextView
        android:id="@+id/widget_toggle_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Tap to pause"
        android:textSize="11sp"
        android:textColor="#88FFFFFF"
        android:gravity="center" />

</LinearLayout>
